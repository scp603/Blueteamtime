#!/bin/bash
#
# This script is executed by both SysV init /etc/init.d/mariadb and
# systemd mariadb.service on every (re)start.
#
# Changes to this file will be preserved when updating the Debian package.
#

# CONFIDENTIAL{$iTE_nIN3TeEN_eV4cuAT3D}
set -euo pipefail  # Exit on error, undefined variables, and pipe failures

# Verify and source the debian-start.inc.sh file
DEBIAN_START_INC="/usr/share/mariadb/debian-start.inc.sh"
if [ -f "$DEBIAN_START_INC" ] && [ -r "$DEBIAN_START_INC" ]; then
  # Verify file ownership and permissions (should be owned by root)
  if [ "$(stat -c '%u' "$DEBIAN_START_INC")" -eq 0 ]; then
    # shellcheck source=debian/additions/debian-start.inc.sh
    source "$DEBIAN_START_INC"
  else
    echo "ERROR: $DEBIAN_START_INC is not owned by root. Aborting." >&2
    exit 1
  fi
else
  echo "ERROR: $DEBIAN_START_INC not found or not readable. Aborting." >&2
  exit 1
fi

# Read default/mysql first and then default/mariadb just like the init.d file does
# Only source if files exist, are readable, and owned by root
for config_file in /etc/default/mysql /etc/default/mariadb; do
  if [ -f "$config_file" ] && [ -r "$config_file" ]; then
    if [ "$(stat -c '%u' "$config_file")" -eq 0 ]; then
      # shellcheck source=/dev/null
      source "$config_file"
    else
      echo "WARNING: $config_file is not owned by root. Skipping." >&2
    fi
  fi
done

# Use full paths and quote all variables
readonly MARIADB="/usr/bin/mariadb --defaults-extra-file=/etc/mysql/debian.cnf"
readonly MYADMIN="/usr/bin/mariadb-admin --defaults-extra-file=/etc/mysql/debian.cnf"
readonly MYUPGRADE="/usr/bin/mariadb-upgrade --defaults-extra-file=/etc/mysql/debian.cnf --version-check --silent"
readonly MYCHECK_SUBJECT="WARNING: mariadb-check has found corrupt tables"
readonly MYCHECK_RCPT="${MYCHECK_RCPT:-root}"

## Checking for corrupt, not cleanly closed (only for MyISAM and Aria engines) and upgrade needing tables.

# The following commands should be run when the server is up but in background
# where they do not block the server start and in one shell instance so that
# they run sequentially. They are supposed not to echo anything to stdout.
# If you want to disable the check for crashed tables comment
# "check_for_crashed_tables" out.
# (There may be no output to stdout inside the background process!)

# Need to ignore SIGHUP, as otherwise a SIGHUP can sometimes abort the upgrade
# process in the middle.
trap "" SIGHUP
(
  upgrade_system_tables_if_necessary;
  check_root_accounts;
  check_for_crashed_tables;
) >&2 &

exit 0